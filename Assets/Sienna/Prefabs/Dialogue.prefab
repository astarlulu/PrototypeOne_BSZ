  text: {fileID: 8943850030623226120}
  dialogueText: {fileID: 3609402699483564443}
  dialogues:
  - A sign? I can't read it from here, I'll have to get closer.
  - So many mushrooms... At least I know I'm in the right place.
  - This forest is so abandoned, the spiders must be forced to make webs this big
    just to catch food.
  - I wonder if they could evolve to eat the mushrooms...
  indexStart: 0
  indexEnd: 0
  index: 0
  writingSpeed: 0.05
  started: 0
  waitForNext: 0
  waiting: 0
